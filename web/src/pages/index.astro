---
import Layout from "../layouts/Layout.astro";
const marketplace = "https://plugins.jetbrains.com/plugin/32393-prompt-bundler";
const coffee = "https://buymeacoffee.com/dorian.naaji";
const github = "https://github.com/DorianNaaji/prompt-bundler";
---
<Layout title="PromptBundler - Get your codebase into any AI chat">
  <style>
    /* ── Layout ─────────────────────────────────────── */
    .container { max-width: 860px; margin: 0 auto; padding: 0 24px; }

    /* ── Nav ─────────────────────────────────────────── */
    nav {
      position: sticky; top: 0; z-index: 10;
      background: rgba(13,15,20,0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      padding: 14px 0;
    }
    nav .inner {
      max-width: 860px; margin: 0 auto; padding: 0 24px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .logo {
      font-size: 1rem; font-weight: 700; letter-spacing: -0.02em;
      color: var(--text); display: flex; align-items: center; gap: 8px;
    }
    .logo-bracket { color: var(--blue); font-size: 1.3rem; line-height: 1; }
    .nav-links { display: flex; gap: 20px; align-items: center; }
    .nav-links a { color: var(--text-muted); font-size: 0.875rem; font-weight: 500; }
    .nav-links a:hover { color: var(--text); text-decoration: none; }

    /* ── Hero ────────────────────────────────────────── */
    .hero {
      padding: 96px 0 72px;
      text-align: center;
    }
    .badge {
      display: inline-flex; align-items: center; gap: 6px;
      background: rgba(76,141,255,0.12); border: 1px solid rgba(76,141,255,0.25);
      color: var(--blue); font-size: 0.75rem; font-weight: 600;
      padding: 4px 12px; border-radius: 100px; margin-bottom: 28px;
      letter-spacing: 0.04em; text-transform: uppercase;
    }
    h1 {
      font-size: clamp(2rem, 5vw, 3.25rem);
      font-weight: 700; letter-spacing: -0.03em; line-height: 1.15;
      margin-bottom: 20px;
    }
    h1 span { color: var(--blue); }
    .hero-sub {
      font-size: 1.125rem; color: var(--text-muted);
      max-width: 540px; margin: 0 auto 40px;
      line-height: 1.7;
    }
    .cta-row {
      display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;
    }
    .btn {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 12px 24px; border-radius: var(--radius);
      font-size: 0.9375rem; font-weight: 600; cursor: pointer;
      transition: opacity 0.15s, transform 0.15s;
    }
    .btn:hover { opacity: 0.88; transform: translateY(-1px); text-decoration: none; }
    .btn-primary { background: var(--blue); color: #fff; }
    .btn-ghost {
      background: var(--surface-2); color: var(--text);
      border: 1px solid var(--border);
    }
    .btn-coffee {
      background: #FFDD00; color: #1a1400; font-weight: 700;
    }

    /* ── Terminal mock ──────────────────────────────── */
    .terminal-wrap { margin: 64px 0 0; }
    .terminal {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 12px; overflow: hidden;
      text-align: left; box-shadow: 0 24px 64px rgba(0,0,0,0.5);
    }
    .term-header {
      background: var(--surface-2); padding: 12px 16px;
      display: flex; align-items: center; gap: 8px;
    }
    .dot { width: 10px; height: 10px; border-radius: 50%; }
    .dot-r { background: #FF5F57; }
    .dot-y { background: #FEBC2E; }
    .dot-g { background: #28C840; }
    .term-title { font-size: 0.75rem; color: var(--text-muted); margin-left: auto; }
    .term-body { padding: 20px 24px; font-family: 'JetBrains Mono', monospace; font-size: 0.825rem; line-height: 1.8; }
    .t-comment { color: #4A5068; }
    .t-key { color: var(--gray); }
    .t-val { color: var(--blue); }
    .t-str { color: #7EC8A4; }
    .t-dim { color: var(--text-muted); }

    /* ── Sections ────────────────────────────────────── */
    section { padding: 80px 0; }
    section + section { border-top: 1px solid var(--border); }
    .section-label {
      font-size: 0.75rem; font-weight: 700; letter-spacing: 0.08em;
      text-transform: uppercase; color: var(--blue); margin-bottom: 12px;
    }
    h2 {
      font-size: clamp(1.5rem, 3vw, 2.125rem);
      font-weight: 700; letter-spacing: -0.02em; margin-bottom: 16px;
    }
    .section-lead {
      font-size: 1.0625rem; color: var(--text-muted);
      max-width: 620px; line-height: 1.75; margin-bottom: 48px;
    }

    /* ── How it works ───────────────────────────────── */
    .steps { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 24px; }
    .step {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 28px 24px;
    }
    .step-num {
      width: 32px; height: 32px; border-radius: 8px;
      background: rgba(76,141,255,0.15); color: var(--blue);
      display: flex; align-items: center; justify-content: center;
      font-weight: 700; font-size: 0.875rem; margin-bottom: 16px;
    }
    .step h3 { font-size: 0.9375rem; font-weight: 600; margin-bottom: 8px; }
    .step p { font-size: 0.875rem; color: var(--text-muted); line-height: 1.6; }

    /* ── Features ────────────────────────────────────── */
    .features { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; }
    .feature {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 24px;
      display: flex; gap: 16px;
    }
    .feat-icon {
      width: 40px; height: 40px; border-radius: 8px; flex-shrink: 0;
      background: rgba(76,141,255,0.12);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.25rem;
    }
    .feature h3 { font-size: 0.9375rem; font-weight: 600; margin-bottom: 4px; }
    .feature p { font-size: 0.8125rem; color: var(--text-muted); line-height: 1.6; }

    /* ── Privacy ─────────────────────────────────────── */
    .privacy-card {
      background: var(--surface);
      border: 1px solid rgba(76,141,255,0.2);
      border-radius: 12px; padding: 40px;
      display: flex; gap: 32px; align-items: flex-start;
    }
    .privacy-icon { font-size: 2.5rem; flex-shrink: 0; }
    .privacy-card h3 { font-size: 1.125rem; font-weight: 700; margin-bottom: 10px; }
    .privacy-card p { color: var(--text-muted); line-height: 1.75; font-size: 0.9375rem; }
    .pill-row { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 16px; }
    .pill {
      background: rgba(76,141,255,0.1); border: 1px solid rgba(76,141,255,0.2);
      color: var(--blue); font-size: 0.75rem; font-weight: 600;
      padding: 4px 10px; border-radius: 100px;
    }

    /* ── Support ─────────────────────────────────────── */
    .support-card {
      text-align: center;
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 12px; padding: 56px 40px;
    }
    .support-card h2 { margin-bottom: 14px; }
    .support-card p { color: var(--text-muted); max-width: 440px; margin: 0 auto 32px; line-height: 1.75; }

    /* ── Footer ──────────────────────────────────────── */
    footer {
      border-top: 1px solid var(--border);
      padding: 28px 0; text-align: center;
    }
    footer p { font-size: 0.8125rem; color: var(--text-muted); }
    footer a { color: var(--text-muted); }
    footer a:hover { color: var(--text); }

    @media (max-width: 600px) {
      .privacy-card { flex-direction: column; gap: 16px; padding: 28px 20px; }
      .nav-links { display: none; }
    }
  </style>

  <!-- Nav -->
  <nav>
    <div class="inner">
      <span class="logo">
        <span class="logo-bracket">{`{`}</span>
        PromptBundler
        <span class="logo-bracket">{`}`}</span>
      </span>
      <div class="nav-links">
        <a href="#how-it-works">How it works</a>
        <a href="#privacy">Privacy</a>
        <a href={github}>GitHub</a>
        <a href={coffee} class="btn btn-coffee" style="padding:6px 14px;font-size:0.8125rem;">☕ Support</a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <div class="hero container">
    <div class="badge">JetBrains Plugin</div>
    <h1>Get your codebase into<br /><span>any AI chat</span>,<br />without the copy-paste hell.</h1>
    <p class="hero-sub">
      Pick files and folders in your IDE. PromptBundler assembles one clean,
      structured prompt and puts it on your clipboard - ready to paste into
      ChatGPT, Claude, Gemini, or any LLM your company uses.
    </p>
    <div class="cta-row">
      <a href={marketplace} class="btn btn-primary">Get on JetBrains Marketplace</a>
      <a href={github} class="btn btn-ghost">View on GitHub</a>
    </div>
    <div style="margin-top:20px;display:flex;gap:16px;justify-content:center;align-items:center;flex-wrap:wrap;">
      <iframe width="245" height="48" src="https://plugins.jetbrains.com/embeddable/install/32393" frameborder="0" allowtransparency="true" style="border:none;"></iframe>
    </div>

    <!-- Terminal mock -->
    <div class="terminal-wrap">
      <div class="terminal">
        <div class="term-header">
          <span class="dot dot-r"></span>
          <span class="dot dot-y"></span>
          <span class="dot dot-g"></span>
          <span class="term-title">PromptBundler output</span>
        </div>
        <div class="term-body">
          <div><span class="t-comment"># Project context</span></div>
          <div><span class="t-key">tree:</span></div>
          <div>&nbsp;&nbsp;<span class="t-dim">src/</span></div>
          <div>&nbsp;&nbsp;&nbsp;&nbsp;<span class="t-dim">auth/</span></div>
          <div>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="t-str">middleware.ts</span></div>
          <div>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="t-str">session.ts</span></div>
          <div>&nbsp;&nbsp;&nbsp;&nbsp;<span class="t-str">App.tsx</span></div>
          <div>&nbsp;</div>
          <div><span class="t-key">files:</span></div>
          <div>&nbsp;&nbsp;<span class="t-comment">--- src/auth/middleware.ts ---</span></div>
          <div>&nbsp;&nbsp;<span class="t-val">export function</span> <span class="t-str">authMiddleware</span><span class="t-dim">(req, res, next) {'{'} ... {'}'}</span></div>
          <div>&nbsp;</div>
          <div><span class="t-key">query:</span> <span class="t-str">"Why is the token expiring early?"</span></div>
          <div>&nbsp;</div>
          <div><span class="t-comment"># → copied to clipboard. Paste anywhere.</span></div>
        </div>
      </div>
    </div>
  </div>

  <!-- How it works -->
  <section id="how-it-works">
    <div class="container">
      <p class="section-label">How it works</p>
      <h2>Three steps, zero friction</h2>
      <p class="section-lead">
        No configuration, no API key, no account. Install the plugin and use it instantly.
      </p>
      <div class="steps">
        <div class="step">
          <div class="step-num">1</div>
          <h3>Select your context</h3>
          <p>Right-click files or folders in the Project view, drag them in, use the editor selection, or the quick picker.</p>
        </div>
        <div class="step">
          <div class="step-num">2</div>
          <h3>Ask your question</h3>
          <p>Type your question in the tool window. PromptBundler assembles a structured prompt with the file tree and exact contents.</p>
        </div>
        <div class="step">
          <div class="step-num">3</div>
          <h3>Paste anywhere</h3>
          <p>Your prompt is on the clipboard. Paste it into ChatGPT, Claude, Gemini, Copilot, or your company's internal LLM.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section>
    <div class="container">
      <p class="section-label">Features</p>
      <h2>Everything you need, nothing you don't</h2>
      <p class="section-lead">
        PromptBundler is a focused tool. It does one thing well: get your code into any AI chat without friction.
      </p>
      <div class="features">
        <div class="feature">
          <div class="feat-icon">🗂</div>
          <div>
            <h3>Flexible context gathering</h3>
            <p>Attach files via the Project view, editor selection, drag-and-drop, or a quick picker. Mix and match.</p>
          </div>
        </div>
        <div class="feature">
          <div class="feat-icon">🌍</div>
          <div>
            <h3>Works with any AI</h3>
            <p>ChatGPT, Claude, Gemini, Mistral, Microsoft 365 Copilot, or your company's self-hosted LLM. Output is plain text.</p>
          </div>
        </div>
        <div class="feature">
          <div class="feat-icon">🧹</div>
          <div>
            <h3>Smart filtering</h3>
            <p>Binary files and oversized files are skipped automatically. Only relevant text content is included.</p>
          </div>
        </div>
        <div class="feature">
          <div class="feat-icon">📋</div>
          <div>
            <h3>Consistent output</h3>
            <p>Every prompt follows the same template: file tree, then contents, then your question. Customizable.</p>
          </div>
        </div>
        <div class="feature">
          <div class="feat-icon">🕓</div>
          <div>
            <h3>Prompt history</h3>
            <p>Past prompts are saved so you can review, reuse, or build on them across sessions.</p>
          </div>
        </div>
        <div class="feature">
          <div class="feat-icon">💡</div>
          <div>
            <h3>Save your agent credits</h3>
            <p>Your IDE agent is capped and expensive. Send big context questions to the web subscription your company already pays for.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Privacy -->
  <section id="privacy">
    <div class="container">
      <p class="section-label">Privacy</p>
      <h2>Your code never leaves your machine</h2>
      <p class="section-lead">
        PromptBundler runs entirely offline. There is nothing to trust except your own clipboard.
      </p>
      <div class="privacy-card">
        <div class="privacy-icon">🔒</div>
        <div>
          <h3>No API calls. No account. No network.</h3>
          <p>
            PromptBundler reads the files you pick and writes structured text to your clipboard.
            Your code never leaves your machine until <em>you</em> paste it, yourself, into the
            chat your company approves. Nothing is sent to any server. Nothing is stored outside your IDE.
          </p>
          <div class="pill-row">
            <span class="pill">100% local</span>
            <span class="pill">No telemetry</span>
            <span class="pill">No account</span>
            <span class="pill">Open source</span>
            <span class="pill">MIT license</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Support -->
  <section>
    <div class="container">
      <div class="support-card">
        <p class="section-label" style="justify-content:center;display:flex;">Support</p>
        <h2>If it saved you from copy-paste hell</h2>
        <p>
          PromptBundler is free, open source, and runs entirely offline with no API, no account, and no strings attached.
          If you find it useful, a coffee goes a long way.
        </p>
        <div class="cta-row">
          <a href={coffee} class="btn btn-coffee">☕ Buy Me a Coffee</a>
          <a href={github} class="btn btn-ghost">⭐ Star on GitHub</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer>
    <div class="container">
      <p>
        <a href={github}>PromptBundler</a> - MIT license -
        Built by <a href="https://github.com/DorianNaaji">Dorian Naaji</a>
      </p>
    </div>
  </footer>
</Layout>
